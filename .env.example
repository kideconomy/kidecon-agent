# Kidecon Agent - example environment variables.
# Copy to .env and adjust for your environment. Never commit the real .env.
#
# This .env is read by the Kilo IDE tool for AI model access.
# All agent-specific secrets (API keys, JWTs) are stored in the OS keyring,
# not here. Use `kidecon key add` to manage those.

# OpenRouter API key (for Kilo IDE AI model access)
OPENROUTER_API_KEY=your-openrouter-key-here

# LLM provider API keys are stored in keyring via:
#   kidecon key add --name <provider> --value <key>
# Provider is set in kidecon.yaml under 'llm.provider'
# Supported providers: openrouter, together, deepseek
